{
  "name": "evo-md",
  "version": "2.0.0",
  "description": "Evo MD - Advanced WhatsApp Pair Code Generator with Guardian UI",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "sync": "node sync.js",
    "cleanup": "node scripts/cleanup.js",
    "build": "echo 'No build step required'",
    "pm2": "pm2 start index.js --name evo-md",
    "pm2:stop": "pm2 stop evo-md",
    "pm2:restart": "pm2 restart evo-md",
    "pm2:logs": "pm2 logs evo-md",
    "test": "node --test",
    "lint": "eslint ."
  },
  "keywords": [
    "whatsapp",
    "bot",
    "pair-code",
    "qr-code",
    "evo-md",
    "guardian",
    "whatsapp-session"
  ],
  "author": "Evo MD Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/evo_pair_site/pair_site.git"
  },
  "bugs": {
    "url": "https://github.com/evo_pair_site/pair_site/issues"
  },
  "homepage": "https://github.com/evo_pair_site/pair_site#readme",
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.0",
    "awesome-phonenumber": "^6.2.0",
    "axios": "^1.7.2",
    "body-parser": "^1.20.2",
    "chalk": "^5.3.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "cron": "^3.1.7",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "fs-extra": "^11.2.0",
    "helmet": "^7.1.0",
    "jimp": "^0.22.12",
    "megajs": "^1.4.0",
    "morgan": "^1.10.0",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "qrcode": "^1.5.3",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.33.4",
    "simple-git": "^3.25.0",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "eslint": "^9.5.0",
    "nodemon": "^3.1.3",
    "prettier": "^3.3.2"
  },
  "nodemonConfig": {
    "watch": [
      ".",
      "mega_sessions"
    ],
    "ext": "js,json,html,css",
    "ignore": [
      "mega_sessions/*",
      "logs/*"
    ],
    "delay": "1000"
  },
  "imports": {
    "#utils/*": "./utils/*.js",
    "#services/*": "./services/*.js",
    "#models/*": "./models/*.js"
  }
  }
